---
/*
File purpose: render the top navigation and brand area for the landing page.
Why this exists: the page needs a lightweight orienting header that supports quick jumps without stealing focus from the hero.
What it does: shows the service label, anchor links, and the primary consultation action.
Connected to: `src/shared/config/site.ts`, `src/shared/ui/button/Button.astro`, and the hero section below it.
*/

import { site } from "@/shared/config/site";
import Button from "@/shared/ui/button/Button.astro";

// When rendered on a non-root page (e.g. /privacy), anchor links need the
// root path prefix so they navigate back to the landing page section.
const isHome = Astro.url.pathname === "/";
const base = isHome ? "" : "/";
---

<header>
  <div class="fixed inset-x-0 top-0 z-50 border-b border-[rgba(15,23,42,0.06)] bg-[rgba(255,255,255,0.66)] shadow-[0_10px_30px_rgba(15,23,42,0.04)] backdrop-blur-2xl">
    <div class="grid h-[72px] w-full grid-cols-[1fr_auto_1fr] items-center gap-4 px-4 sm:px-5 lg:px-6">
      <a href="/" class="inline-flex items-center leading-none">
        <img src="/ЦЭР%20лого%20черное.svg" alt="ЦЭР" class="h-16 w-auto" />
      </a>

      <nav class="hidden items-center justify-self-center gap-2 lg:flex" aria-label="Primary">
        {site.nav.map((item) => (
          <a
            href={`${base}${item.href}`}
            class="rounded-full px-4 py-2 text-sm font-medium text-[color:var(--text-muted)] transition hover:bg-[rgba(15,23,42,0.06)] hover:text-[color:var(--text)]"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center justify-self-end gap-3">
        <span class="hidden text-sm font-medium text-[color:var(--text-muted)] lg:inline-flex">
          {site.contacts.infoEmail}
        </span>
        <!-- Mobile: icon-only button. sm+: full label -->
        <Button
          href={`${base}${site.actions.consultation.href}`}
          variant="secondary"
          class="px-3 sm:px-6 hover:border-[rgba(183,111,42,0.5)] hover:text-[#b96a27] hover:shadow-[0_10px_24px_rgba(183,111,42,0.12)]"
          leadingIcon="chat-conversation"
          data-feedback-open
          aria-haspopup="dialog"
          aria-controls="feedback-modal"
        >
          <span class="hidden sm:inline">{site.actions.consultation.label}</span>
        </Button>
      </div>
    </div>
  </div>
</header>
