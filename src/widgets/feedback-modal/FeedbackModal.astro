---
/*
File purpose: provide a lightweight feedback modal for consultation requests.
Why this exists: the landing page needs a simple lead-capture interaction that can be opened from multiple CTAs without duplicating form logic.
What it does: renders an accessible overlay panel with two required fields, handles open and close interactions, preserves scroll position, and shows a small success state after submit.
Connected to: the consultation buttons in the header, hero, and CTA block, plus the shared button primitive.
*/

import { site } from "@/shared/config/site";
import Button from "@/shared/ui/button/Button.astro";
import Card from "@/shared/ui/card/Card.astro";
---

<div
  data-feedback-modal
  aria-hidden="true"
  class="fixed inset-0 z-[60] hidden items-center justify-center p-4 text-[color:var(--text)] outline-none"
>
  <div aria-hidden="true" class="absolute inset-0 bg-[rgba(15,23,42,0.64)] backdrop-blur-[10px]"></div>
  <div class="absolute inset-0 bg-[rgba(15,23,42,0.28)]"></div>

  <div data-feedback-backdrop class="relative z-10 flex min-h-full w-full items-center justify-center">
    <Card
      data-feedback-panel
      role="dialog"
      aria-modal="true"
      aria-labelledby="feedback-modal-title"
      aria-describedby="feedback-modal-description"
      class="relative w-full max-w-[560px] overflow-hidden"
    >
      <button
        type="button"
        data-feedback-close
        aria-label={site.feedback.closeLabel}
        class="absolute right-5 top-5 inline-flex h-10 w-10 items-center justify-center rounded-full border border-[color:var(--border)] bg-white text-xl leading-none text-[color:var(--text-muted)] transition hover:border-[rgba(183,111,42,0.48)] hover:text-[#b96a27]"
      >
        ×
      </button>

      <h2 id="feedback-modal-title" class="mt-5 text-3xl leading-tight">
        {site.feedback.title}
      </h2>
      <p id="feedback-modal-description" class="mt-3 max-w-lg text-base leading-7 text-[color:var(--text-muted)]">
        {site.feedback.description}
      </p>

      <form data-feedback-form class="mt-8 grid gap-4">
        <input name="leadType" type="hidden" value="consultation" />
        <input name="source" type="hidden" value="Консультация" />
        <input name="payload" type="hidden" value="" />

        <label class="block">
          <span class="mb-2 block text-sm font-semibold text-[color:var(--text-muted)]">{site.feedback.nameLabel}</span>
          <input
            name="name"
            type="text"
            autocomplete="name"
            placeholder={site.feedback.namePlaceholder}
            required
            class="w-full rounded-2xl border border-[color:var(--border)] bg-white px-4 py-3 text-base text-[color:var(--text)] outline-none transition focus:border-[color:var(--brand)] focus:ring-2 focus:ring-[color:var(--brand-soft)]"
          />
        </label>

        <label class="block">
          <span class="mb-2 block text-sm font-semibold text-[color:var(--text-muted)]">{site.feedback.phoneLabel}</span>
          <input
            name="phone"
            type="tel"
            autocomplete="tel"
            inputmode="tel"
            placeholder={site.feedback.phonePlaceholder}
            required
            class="w-full rounded-2xl border border-[color:var(--border)] bg-white px-4 py-3 text-base text-[color:var(--text)] outline-none transition focus:border-[color:var(--brand)] focus:ring-2 focus:ring-[color:var(--brand-soft)]"
          />
        </label>

        <div class="mt-2 flex flex-col gap-3 sm:flex-row">
          <Button as="button" type="submit" variant="primary" class="sm:flex-1">
            {site.feedback.submitLabel}
          </Button>
        </div>
        <p data-feedback-error class="hidden rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm leading-6 text-red-700">
          Не удалось отправить заявку. Попробуйте ещё раз или свяжитесь с нами напрямую.
        </p>
        <p class="text-sm leading-6 text-[color:var(--text-muted)]">
          {site.feedback.consentLead}
          <a href="/privacy" class="text-[color:var(--text)] underline decoration-[color:var(--border)] underline-offset-4 transition hover:decoration-[rgba(183,111,42,0.48)] hover:text-[#b96a27]">
            {site.feedback.consentLinkLabel}
          </a>
        </p>
      </form>

      <div data-feedback-success class="mt-8 hidden rounded-[28px] border border-[color:var(--brand-soft)] bg-[rgba(28,79,215,0.06)] p-5">
        <p class="text-xl leading-tight">{site.feedback.successTitle}</p>
        <p class="mt-2 text-sm leading-7 text-[color:var(--text-muted)]">
          {site.feedback.successLead}
        </p>
      </div>
    </Card>
  </div>
</div>

<script>
  /*
   * Wire the modal to every consultation CTA on the page.
   * The interaction stays lightweight: open from any button, lock background scroll without losing position, and show a small success state after submit.
   */
  const modal = document.querySelector<HTMLElement>("[data-feedback-modal]");

  if (!modal) {
    throw new Error("Feedback modal was not found.");
  }

  const openButtons = document.querySelectorAll<HTMLElement>("[data-feedback-open]");
  const backdrop = modal.querySelector<HTMLElement>("[data-feedback-backdrop]");
  const closeButtons = modal.querySelectorAll<HTMLElement>("[data-feedback-close]");
  const form = modal.querySelector<HTMLFormElement>("[data-feedback-form]");
  const success = modal.querySelector<HTMLElement>("[data-feedback-success]");
  const firstInput = modal.querySelector<HTMLInputElement>('input[name="name"]');
  const leadTypeInput = modal.querySelector<HTMLInputElement>('input[name="leadType"]');
  const sourceInput = modal.querySelector<HTMLInputElement>('input[name="source"]');
  const payloadInput = modal.querySelector<HTMLInputElement>('input[name="payload"]');
  const submitButton = form?.querySelector<HTMLButtonElement>('button[type="submit"]');
  const errorMessage = modal.querySelector<HTMLElement>("[data-feedback-error]");

  let savedScrollY = 0;
  let lastTrigger: HTMLElement | null = null;

  /*
   * Lock the background page without losing the current scroll position.
   * This prevents the modal from snapping the document back to the top when it opens.
   */
  const lockScroll = () => {
    savedScrollY = window.scrollY;
    document.documentElement.style.overflow = "hidden";
    document.body.style.position = "fixed";
    document.body.style.top = `-${savedScrollY}px`;
    document.body.style.left = "0";
    document.body.style.right = "0";
    document.body.style.width = "100%";
  };

  /*
   * Restore the page scroll after the modal closes.
   * This returns the user to the exact point where they opened the dialog.
   */
  const unlockScroll = () => {
    const root = document.documentElement;
    const previousScrollBehavior = root.style.scrollBehavior;

    /*
     * Temporarily disable the global smooth-scrolling rule from `src/app/styles/global.css`.
     * Without this override, restoring `window.scrollTo` can animate the whole page from the top to the saved position, which feels like a jump when the modal closes.
     */
    root.style.scrollBehavior = "auto";
    root.style.overflow = "";
    document.body.style.position = "";
    document.body.style.top = "";
    document.body.style.left = "";
    document.body.style.right = "";
    document.body.style.width = "";
    window.scrollTo(0, savedScrollY);
    requestAnimationFrame(() => {
      root.style.scrollBehavior = previousScrollBehavior;
    });
  };

  /*
   * Reset the modal into its initial state before showing it again.
   * This keeps repeat opens predictable if the user comes back after a successful submit.
   */
  const resetModal = () => {
    form?.reset();
    if (leadTypeInput) {
      leadTypeInput.value = "consultation";
    }
    if (sourceInput) {
      sourceInput.value = "Консультация";
    }
    if (payloadInput) {
      payloadInput.value = "";
    }
    if (submitButton) {
      submitButton.disabled = false;
      submitButton.textContent = "Отправить";
    }
    errorMessage?.classList.add("hidden");
    form?.classList.remove("hidden");
    success?.classList.add("hidden");
  };

  /*
   * Open the modal, make it visible, and focus the first field without moving the document.
   * Using a custom overlay instead of <dialog> avoids browser-specific scroll jumps.
   */
  const openModal = (trigger: HTMLElement) => {
    lastTrigger = trigger;
    resetModal();
    if (leadTypeInput) {
      leadTypeInput.value = trigger.dataset.leadType || "consultation";
    }
    if (sourceInput) {
      sourceInput.value = trigger.dataset.leadSource || trigger.textContent?.trim() || "Консультация";
    }
    if (payloadInput) {
      payloadInput.value = trigger.dataset.leadPayload || "";
    }
    modal.classList.remove("hidden");
    modal.setAttribute("aria-hidden", "false");
    lockScroll();
    requestAnimationFrame(() => {
      firstInput?.focus({ preventScroll: true });
    });
  };

  /*
   * Close the modal, hide the overlay, restore the scroll position, and return focus to the opener.
   * This keeps keyboard and pointer users in the same place they started from.
   */
  const closeModal = () => {
    modal.classList.add("hidden");
    modal.setAttribute("aria-hidden", "true");
    unlockScroll();
    lastTrigger?.focus({ preventScroll: true });
  };

  openButtons.forEach((button) => {
    button.addEventListener("click", (event) => {
      event.preventDefault();
      openModal(button);
    });
  });

  closeButtons.forEach((button) => {
    button.addEventListener("click", closeModal);
  });

  backdrop?.addEventListener("click", (event) => {
    if (event.target === backdrop) {
      closeModal();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && !modal.classList.contains("hidden")) {
      closeModal();
    }
  });

  /*
   * Send the lead to the site API, then switch to a success state only after the mail provider accepts it.
   */
  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    errorMessage?.classList.add("hidden");

    if (!form.reportValidity()) {
      return;
    }

    const formData = new FormData(form);
    const payloadRaw = String(formData.get("payload") || "");
    let payload: unknown = null;

    if (payloadRaw) {
      try {
        payload = JSON.parse(payloadRaw);
      } catch {
        payload = payloadRaw;
      }
    }

    if (submitButton) {
      submitButton.disabled = true;
      submitButton.textContent = "Отправляем...";
    }

    try {
      const response = await fetch("/api/lead", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          name: formData.get("name"),
          phone: formData.get("phone"),
          leadType: formData.get("leadType"),
          source: formData.get("source"),
          payload,
        }),
      });

      if (!response.ok) {
        throw new Error("Lead request failed.");
      }

      form.classList.add("hidden");
      success?.classList.remove("hidden");
    } catch {
      errorMessage?.classList.remove("hidden");
      if (submitButton) {
        submitButton.disabled = false;
        submitButton.textContent = "Отправить";
      }
    }
  });
</script>
