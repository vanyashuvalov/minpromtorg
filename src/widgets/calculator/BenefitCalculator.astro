---
/*
File purpose: present the landing-page benefit calculator as a business comparison block.
Why this exists: the page needs a single, reusable widget that shows the difference between self-managed work and full сопровождение in time, effort, and money.
What it does: renders three sliders, computes a nonlinear comparison model, and displays the result in a stronger split-card layout.
Connected to: `src/shared/config/calculator.ts`, `src/shared/lib/benefit-calculator.ts`, `src/shared/ui/button/Button.astro`, `src/shared/ui/card/Card.astro`, `src/shared/ui/icon/Icon.astro`, and `src/shared/ui/section/Section.astro`.
*/

import { calculatorContent } from "@/shared/config/calculator";
import Button from "@/shared/ui/button/Button.astro";
import Card from "@/shared/ui/card/Card.astro";
import Icon from "@/shared/ui/icon/Icon.astro";
import Section from "@/shared/ui/section/Section.astro";
const savingsIcon = "trending-up";
---

<Section id="calculator" title={calculatorContent.title} lead={calculatorContent.lead}>
  <div class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
    <Card padding="lg" class="relative overflow-hidden">
      <!-- Decorative panel background: the calculator needs a calmer surface so the slider inputs and labels stay readable against the section background. -->
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(28,79,215,0.08),transparent_36%),radial-gradient(circle_at_bottom_left,rgba(233,184,115,0.12),transparent_30%)]"></div>

      <div class="relative">
        <p class="mt-2 text-2xl leading-tight text-[color:var(--text)]">
          Ваши параметры
        </p>

        <!-- Slider stack: the left column captures the user inputs that drive the business model and keeps them visually grouped for fast tuning. -->
        <div class="mt-5 grid gap-5">
          <label class="block">
            <div class="flex items-center justify-between gap-4">
              <div>
                <span class="block text-sm font-semibold text-[color:var(--text-muted)]">
                  {calculatorContent.sliders.positions.label}
                </span>
              </div>
              <span data-field="positionsValue" class="text-sm font-semibold text-[color:var(--text)]">3</span>
            </div>
            <input
              data-field="positions"
              type="range"
              min="1"
              max="5"
              step="1"
              value={calculatorContent.defaults.positions}
              class="calculator-range mt-5 w-full"
            />
          </label>

          <label class="block">
            <div class="flex items-center justify-between gap-4">
              <div>
                <span class="block text-sm font-semibold text-[color:var(--text-muted)]">
                  {calculatorContent.sliders.hourlyRate.label}
                </span>
              </div>
              <span data-field="hourlyRateValue" class="text-sm font-semibold text-[color:var(--text)]">1 500 ₽</span>
            </div>
            <input
              data-field="hourlyRate"
              type="range"
              min="500"
              max="3000"
              step="100"
              value={calculatorContent.defaults.hourlyRate}
              class="calculator-range mt-5 w-full"
            />
          </label>

          <label class="block">
            <div class="flex items-center justify-between gap-4">
              <div>
                <span class="block text-sm font-semibold text-[color:var(--text-muted)]">
                  {calculatorContent.sliders.employees.label}
                </span>
              </div>
              <span data-field="employeesValue" class="text-sm font-semibold text-[color:var(--text)]">3</span>
            </div>
            <input
              data-field="employees"
              type="range"
              min="1"
              max="5"
              step="1"
              value={calculatorContent.defaults.employees}
              class="calculator-range mt-5 w-full"
            />
          </label>
        </div>

        <!-- Supporting context: this helper block explains the model so the visitor understands why the result grows faster than the sliders themselves. -->
        <div class="mt-8">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--text-soft)]">
            Что учитывает модель
          </p>
          <div class="mt-4 space-y-3">
            {calculatorContent.benefits.items.map((item) => (
              <div class="flex items-start gap-3">
                <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-[color:var(--brand-soft)] text-[color:var(--brand)]">
                  <Icon name="check-big" size={12} />
                </span>
                <span class="text-sm leading-6 text-[color:var(--text-muted)]">{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </Card>

    <div class="grid gap-4">
      <!-- Scenario cards: the right column translates the calculation into an immediate commercial comparison that is easy to scan on mobile and desktop. -->
      <div class="grid gap-4 sm:grid-cols-2">
        <Card class="relative overflow-hidden p-6 sm:p-7">
          <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.96),rgba(245,248,252,0.98))]"></div>
          <div class="relative">
            <p class="mt-2 text-2xl leading-tight text-[color:var(--text)]">
              {calculatorContent.summary.self.title}
            </p>
            <p data-result-selfCost class="mt-4 text-3xl leading-none text-[color:var(--text)]">0 ₽</p>

            <div class="mt-5 grid gap-3">
              <div class="flex items-center justify-between rounded-2xl border border-[color:var(--border)] bg-white/80 px-4 py-3">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--text-soft)]">Срок</p>
                <p data-result-selfMonths class="text-xl font-semibold text-[color:var(--text)]">0 мес.</p>
              </div>
              <div class="flex items-center justify-between rounded-2xl border border-[color:var(--border)] bg-white/80 px-4 py-3">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--text-soft)]">Часы</p>
                <p data-result-selfHours class="text-xl font-semibold text-[color:var(--text)]">0 ч</p>
              </div>
            </div>

            <p class="mt-4 text-sm leading-6 text-[color:var(--text-muted)]">
              {calculatorContent.summary.self.description}
            </p>
          </div>
        </Card>

        <Card tone="accent" class="relative overflow-hidden p-6 sm:p-7">
          <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(28,79,215,0.08),rgba(233,184,115,0.14))]"></div>
          <div class="relative">
            <p class="mt-2 text-2xl leading-tight text-[color:var(--text)]">
              {calculatorContent.summary.agency.title}
            </p>
            <p data-result-agencyCost class="mt-4 text-3xl leading-none text-[color:var(--text)]">0 ₽</p>

            <div class="mt-5 grid gap-3">
              <div class="flex items-center justify-between rounded-2xl border border-white/70 bg-white/80 px-4 py-3">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--text-soft)]">Срок</p>
                <p data-result-agencyMonths class="text-xl font-semibold text-[color:var(--text)]">0 мес.</p>
              </div>
              <div class="flex items-center justify-between rounded-2xl border border-white/70 bg-white/80 px-4 py-3">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--text-soft)]">Часы</p>
                <p data-result-agencyHours class="text-xl font-semibold text-[color:var(--text)]">0 ч</p>
              </div>
            </div>

            <p class="mt-4 text-sm leading-6 text-[color:var(--text-muted)]">
              {calculatorContent.summary.agency.description}
            </p>
          </div>
        </Card>
      </div>

      <!-- Savings card: this closes the loop with a single business outcome, which is faster, lighter, and cheaper. -->
      <Card tone="dark" class="relative overflow-hidden p-6 sm:p-7">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(233,184,115,0.14),transparent_35%),radial-gradient(circle_at_bottom_left,rgba(28,79,215,0.22),transparent_30%)]"></div>
        <div class="relative">
          <div class="flex items-center gap-2 text-[color:var(--accent)]">
            <Icon name={savingsIcon} size={18} />
            <p class="text-xs font-semibold uppercase tracking-[0.24em]">{calculatorContent.savings.title}</p>
          </div>

          <div class="mt-5 grid gap-3 sm:grid-cols-3">
            <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-white/52">{calculatorContent.savings.fasterLabel}</p>
              <p data-result-savedMonths class="mt-2 text-2xl font-semibold text-white">0 мес.</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-white/52">{calculatorContent.savings.hoursLabel}</p>
              <p data-result-savedHours class="mt-2 text-2xl font-semibold text-white">0 ч</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-white/52">{calculatorContent.savings.valueLabel}</p>
              <p data-result-savedCost class="mt-2 text-2xl font-semibold text-white">0 ₽</p>
            </div>
          </div>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
            <Button
              as="button"
              type="button"
              variant="primary"
              leadingIcon="chat-conversation"
              data-feedback-open
              data-calculator-lead
              data-lead-type="quiz"
              data-lead-source={calculatorContent.cta.label}
              aria-haspopup="dialog"
              aria-controls="feedback-modal"
            >
              {calculatorContent.cta.label}
            </Button>
            <Button
              as="button"
              type="button"
              variant="secondary"
              leadingIcon="file-document"
              data-feedback-open
              data-calculator-lead
              data-lead-type="quiz"
              data-lead-source={calculatorContent.cta.secondaryLabel}
              aria-haspopup="dialog"
              aria-controls="feedback-modal"
            >
              {calculatorContent.cta.secondaryLabel}
            </Button>
          </div>
        </div>
      </Card>
    </div>
  </div>

  <script>
    /*
     * Keep the sliders and the comparison cards in sync.
     * The widget stays framework-free so it remains fast, predictable, and easy to extend if the business assumptions change later.
     */
    import {
      calculateBenefitComparison,
      clampInput,
      formatCompactRubles,
      formatHours,
      formatMonths,
      formatNumber,
    } from "@/shared/lib/benefit-calculator";

    const root = document.querySelector<HTMLElement>("#calculator");

    if (!root) {
      throw new Error("Calculator root was not found.");
    }

    const positionsInput = root.querySelector<HTMLInputElement>('[data-field="positions"]');
    const hourlyRateInput = root.querySelector<HTMLInputElement>('[data-field="hourlyRate"]');
    const employeesInput = root.querySelector<HTMLInputElement>('[data-field="employees"]');

    const positionsValue = root.querySelector<HTMLElement>('[data-field="positionsValue"]');
    const hourlyRateValue = root.querySelector<HTMLElement>('[data-field="hourlyRateValue"]');
    const employeesValue = root.querySelector<HTMLElement>('[data-field="employeesValue"]');

    const selfCost = root.querySelector<HTMLElement>("[data-result-selfCost]");
    const selfMonths = root.querySelector<HTMLElement>("[data-result-selfMonths]");
    const selfHours = root.querySelector<HTMLElement>("[data-result-selfHours]");
    const agencyCost = root.querySelector<HTMLElement>("[data-result-agencyCost]");
    const agencyMonths = root.querySelector<HTMLElement>("[data-result-agencyMonths]");
    const agencyHours = root.querySelector<HTMLElement>("[data-result-agencyHours]");
    const savedMonths = root.querySelector<HTMLElement>("[data-result-savedMonths]");
    const savedHours = root.querySelector<HTMLElement>("[data-result-savedHours]");
    const savedCost = root.querySelector<HTMLElement>("[data-result-savedCost]");
    const leadButtons = root.querySelectorAll<HTMLElement>("[data-calculator-lead]");

    if (
      !positionsInput ||
      !hourlyRateInput ||
      !employeesInput ||
      !positionsValue ||
      !hourlyRateValue ||
      !employeesValue ||
      !selfCost ||
      !selfMonths ||
      !selfHours ||
      !agencyCost ||
      !agencyMonths ||
      !agencyHours ||
      !savedMonths ||
      !savedHours ||
      !savedCost
    ) {
      throw new Error("Calculator outputs were not found.");
    }

    const rangeMeta = {
      positions: { min: 1, max: 5 },
      hourlyRate: { min: 500, max: 3000 },
      employees: { min: 1, max: 5 },
    } as const;

    const state = {
      positions: Number(positionsInput.value),
      hourlyRate: Number(hourlyRateInput.value),
      employees: Number(employeesInput.value),
    };

    /*
     * Paint the slider track so the fill reflects the current value.
     * The visual fill gives the controls a premium feeling while keeping the markup simple and fully accessible.
     */
    const paintRange = (input: HTMLInputElement, min: number, max: number, value: number) => {
      const safeValue = clampInput(value, min, max);
      const percent = ((safeValue - min) / (max - min)) * 100;

      input.style.background = `linear-gradient(90deg, rgba(28,79,215,0.18) 0%, rgba(28,79,215,0.18) ${percent}%, rgba(226,231,237,1) ${percent}%, rgba(226,231,237,1) 100%)`;
    };

    /*
     * Render the latest numbers into the view.
     * All business assumptions are isolated in the shared lib, so this function only translates the result into visible labels and cards.
     */
    const render = () => {
      const result = calculateBenefitComparison(state);

      positionsInput.value = String(state.positions);
      hourlyRateInput.value = String(state.hourlyRate);
      employeesInput.value = String(state.employees);

      positionsValue.textContent = formatNumber(state.positions);
      hourlyRateValue.textContent = `${formatNumber(state.hourlyRate)} ₽`;
      employeesValue.textContent = formatNumber(state.employees);

      selfCost.textContent = formatCompactRubles(result.self.cost);
      selfMonths.textContent = formatMonths(result.self.months);
      selfHours.textContent = formatHours(result.self.hours);

      agencyCost.textContent = formatCompactRubles(result.agency.cost);
      agencyMonths.textContent = formatMonths(result.agency.months);
      agencyHours.textContent = formatHours(result.agency.hours);

      savedMonths.textContent = formatMonths(result.savings.months);
      savedHours.textContent = formatHours(result.savings.hours);
      savedCost.textContent = formatCompactRubles(result.savings.cost);

      const leadPayload = {
        inputs: {
          positions: state.positions,
          hourlyRate: state.hourlyRate,
          employees: state.employees,
        },
        result: {
          self: {
            cost: formatCompactRubles(result.self.cost),
            months: formatMonths(result.self.months),
            hours: formatHours(result.self.hours),
          },
          agency: {
            cost: formatCompactRubles(result.agency.cost),
            months: formatMonths(result.agency.months),
            hours: formatHours(result.agency.hours),
          },
          savings: {
            months: formatMonths(result.savings.months),
            hours: formatHours(result.savings.hours),
            cost: formatCompactRubles(result.savings.cost),
          },
        },
      };

      leadButtons.forEach((button) => {
        button.dataset.leadPayload = JSON.stringify(leadPayload);
      });

      paintRange(positionsInput, rangeMeta.positions.min, rangeMeta.positions.max, state.positions);
      paintRange(hourlyRateInput, rangeMeta.hourlyRate.min, rangeMeta.hourlyRate.max, state.hourlyRate);
      paintRange(employeesInput, rangeMeta.employees.min, rangeMeta.employees.max, state.employees);
    };

    /*
     * Update the calculator state from a slider change and immediately re-render the comparison.
     * This keeps the widget responsive while preventing any invalid state from leaking into the calculation.
     */
    const updateState = (key: keyof typeof state, value: number, min: number, max: number) => {
      state[key] = clampInput(value, min, max);
      render();
    };

    positionsInput.addEventListener("input", (event) => {
      updateState("positions", Number((event.target as HTMLInputElement).value), rangeMeta.positions.min, rangeMeta.positions.max);
    });

    hourlyRateInput.addEventListener("input", (event) => {
      updateState("hourlyRate", Number((event.target as HTMLInputElement).value), rangeMeta.hourlyRate.min, rangeMeta.hourlyRate.max);
    });

    employeesInput.addEventListener("input", (event) => {
      updateState("employees", Number((event.target as HTMLInputElement).value), rangeMeta.employees.min, rangeMeta.employees.max);
    });

    render();
  </script>

  <style>
    .calculator-range {
      appearance: none;
      -webkit-appearance: none;
      height: 12px;
      border-radius: 999px;
      outline: none;
      background: linear-gradient(90deg, rgba(226, 231, 237, 1) 0%, rgba(226, 231, 237, 1) 100%);
    }

    .calculator-range::-webkit-slider-runnable-track {
      height: 12px;
      border-radius: 999px;
      background: transparent;
    }

    .calculator-range::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 26px;
      height: 26px;
      border-radius: 999px;
      border: 3px solid #fff;
      background: #9aa3b0;
      box-shadow: 0 10px 24px rgba(92, 104, 120, 0.2);
      margin-top: -7px;
    }

    .calculator-range::-webkit-slider-thumb:hover {
      filter: brightness(0.92);
    }

    .calculator-range::-moz-range-track {
      height: 12px;
      border-radius: 999px;
      background: transparent;
    }

    .calculator-range::-moz-range-thumb {
      width: 26px;
      height: 26px;
      border-radius: 999px;
      border: 3px solid #fff;
      background: #9aa3b0;
      box-shadow: 0 10px 24px rgba(92, 104, 120, 0.2);
    }

    .calculator-range::-moz-range-thumb:hover {
      filter: brightness(0.92);
    }
  </style>
</Section>
