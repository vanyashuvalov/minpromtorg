---
/*
File purpose: render the landing page calculator as a centered, slider-driven comparison block.
Why this exists: the page needs a clean benefit widget that shows the cost difference without extra explanatory noise.
What it does: lets the visitor adjust three variables with sliders, recalculates the comparison live, and presents a short result summary with one clear next action.
Connected to: `src/shared/lib/benefit-calculator.ts`, `src/shared/ui/card/Card.astro`, `src/shared/ui/button/Button.astro`, and the feedback modal opened from the CTA below.
*/

import Button from "@/shared/ui/button/Button.astro";
import Card from "@/shared/ui/card/Card.astro";
import Icon from "@/shared/ui/icon/Icon.astro";
import type { CoolIconName } from "@/shared/lib/coolicons";

const sliderDefaults = {
  positions: 4,
  hourlyRate: 2500,
  employees: 3,
} as const;

const savingsIcon: CoolIconName = "trending-up";
---

<section id="calculator" class="scroll-mt-32 px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
  <div class="mx-auto w-full max-w-[720px]">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[color:var(--text-soft)]">
        Калькулятор выгоды
      </p>
      <h2 class="mt-4 text-3xl leading-[0.96] sm:text-4xl lg:text-5xl">
        Посчитайте экономию за пару секунд
      </h2>
      <p class="mt-4 text-base leading-7 text-[color:var(--text-muted)] sm:text-lg">
        Передвиньте три слайдера и сразу увидите разницу между самостоятельной подготовкой и работой под ключ
      </p>
    </div>

    <Card class="mt-10 overflow-hidden p-6 sm:p-8 lg:p-10">
      <div class="grid gap-0">
        <label class="py-5 first:pt-0 border-t border-[color:var(--border)] first:border-t-0">
          <div class="flex items-center justify-between gap-4">
            <span class="text-sm font-semibold text-[color:var(--text-muted)]">Количество позиций</span>
            <span data-field="positionsValue" class="text-sm font-semibold text-[color:var(--text)]">4</span>
          </div>
          <input
            data-field="positions"
            type="range"
            min="1"
            max="24"
            step="1"
            value={sliderDefaults.positions}
            class="calculator-range mt-5 w-full"
          />
        </label>

        <label class="py-5 border-t border-[color:var(--border)]">
          <div class="flex items-center justify-between gap-4">
            <span class="text-sm font-semibold text-[color:var(--text-muted)]">Стоимость часа сотрудника</span>
            <span data-field="hourlyRateValue" class="text-sm font-semibold text-[color:var(--text)]">2 500 ₽</span>
          </div>
          <input
            data-field="hourlyRate"
            type="range"
            min="800"
            max="20000"
            step="100"
            value={sliderDefaults.hourlyRate}
            class="calculator-range mt-5 w-full"
          />
        </label>

        <label class="py-5 border-t border-[color:var(--border)]">
          <div class="flex items-center justify-between gap-4">
            <span class="text-sm font-semibold text-[color:var(--text-muted)]">Количество сотрудников</span>
            <span data-field="employeesValue" class="text-sm font-semibold text-[color:var(--text)]">3</span>
          </div>
          <input
            data-field="employees"
            type="range"
            min="1"
            max="50"
            step="1"
            value={sliderDefaults.employees}
            class="calculator-range mt-5 w-full"
          />
        </label>
      </div>

      <div class="mt-8 grid gap-4 lg:grid-cols-2">
        <Card class="p-5 sm:p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--text-soft)]">Сами</p>
          <p data-field="selfCost" class="mt-3 text-3xl font-semibold text-[color:var(--text)]">0 ₽</p>
        </Card>

        <Card class="p-5 sm:p-6 bg-[linear-gradient(135deg,rgba(28,79,215,0.08),rgba(255,255,255,0.96))]">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--text-soft)]">С нами</p>
          <p data-field="agencyCost" class="mt-3 text-3xl font-semibold text-[color:var(--text)]">0 ₽</p>
        </Card>
      </div>

      <Card class="mt-4 border border-[color:var(--success)] bg-[linear-gradient(135deg,rgba(30,155,93,0.08),rgba(255,255,255,0.98))] p-5 sm:p-6">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <div class="flex items-center gap-2 text-[color:var(--success)]">
              <Icon name={savingsIcon} size={18} />
              <p class="text-xs font-semibold uppercase tracking-[0.18em]">Экономия</p>
            </div>
            <p data-field="savings" class="mt-3 text-4xl font-semibold text-[color:var(--text)]">0 ₽</p>
          </div>
        </div>
      </Card>

      <div class="mt-8 flex justify-center">
        <Button
          as="button"
          type="button"
          variant="primary"
          leadingIcon="file-document"
          data-feedback-open
          aria-haspopup="dialog"
          aria-controls="feedback-modal"
        >
          Получить КП
        </Button>
      </div>
    </Card>
  </div>

  <script>
    /*
     * Keep the slider UI and the shared calculation model in sync.
     * The widget is intentionally framework-free so it stays fast, predictable, and easy to integrate with the rest of the landing page.
     */
    import {
      calculateBenefitComparison,
      clampInput,
      formatNumber,
      formatRubles,
    } from "@/shared/lib/benefit-calculator";

    const root = document.querySelector<HTMLElement>("#calculator");

    if (!root) {
      throw new Error("Calculator root was not found.");
    }

    const positionsInput = root.querySelector<HTMLInputElement>('[data-field="positions"]');
    const hourlyRateInput = root.querySelector<HTMLInputElement>('[data-field="hourlyRate"]');
    const employeesInput = root.querySelector<HTMLInputElement>('[data-field="employees"]');

    const positionsValue = root.querySelector<HTMLElement>('[data-field="positionsValue"]');
    const hourlyRateValue = root.querySelector<HTMLElement>('[data-field="hourlyRateValue"]');
    const employeesValue = root.querySelector<HTMLElement>('[data-field="employeesValue"]');

    const selfCost = root.querySelector<HTMLElement>('[data-field="selfCost"]');
    const agencyCost = root.querySelector<HTMLElement>('[data-field="agencyCost"]');
    const savings = root.querySelector<HTMLElement>('[data-field="savings"]');

    if (
      !positionsInput ||
      !hourlyRateInput ||
      !employeesInput ||
      !positionsValue ||
      !hourlyRateValue ||
      !employeesValue ||
      !selfCost ||
      !agencyCost ||
      !savings
    ) {
      throw new Error("Calculator outputs were not found.");
    }

    const state = {
      positions: 4,
      hourlyRate: 2500,
      employees: 3,
    };

    const rangeMeta = {
      positions: { min: 1, max: 24 },
      hourlyRate: { min: 800, max: 20000 },
      employees: { min: 1, max: 50 },
    } as const;

    /*
     * Paint the slider track so the fill reflects the current value.
     * This gives the controls a tactile, premium feel while keeping the markup simple.
     */
    const paintRange = (input: HTMLInputElement, min: number, max: number, value: number) => {
      const safeValue = clampInput(value, min, max);
      const percent = ((safeValue - min) / (max - min)) * 100;

      input.style.background = `linear-gradient(90deg, rgba(28,79,215,0.16) 0%, rgba(28,79,215,0.16) ${percent}%, rgba(226,231,237,1) ${percent}%, rgba(226,231,237,1) 100%)`;
    };

    /*
     * Render the current state into the value badges and result cards.
     * Keeping a single render path makes the widget easy to tune if the pricing assumptions change later.
     */
    const render = () => {
      const result = calculateBenefitComparison(state);

      positionsInput.value = String(state.positions);
      hourlyRateInput.value = String(state.hourlyRate);
      employeesInput.value = String(state.employees);

      positionsValue.textContent = formatNumber(state.positions);
      hourlyRateValue.textContent = formatRubles(state.hourlyRate);
      employeesValue.textContent = formatNumber(state.employees);

      selfCost.textContent = formatRubles(result.selfCost);
      agencyCost.textContent = formatRubles(result.agencyCost);
      savings.textContent = formatRubles(result.savings);

      paintRange(positionsInput, rangeMeta.positions.min, rangeMeta.positions.max, state.positions);
      paintRange(hourlyRateInput, rangeMeta.hourlyRate.min, rangeMeta.hourlyRate.max, state.hourlyRate);
      paintRange(employeesInput, rangeMeta.employees.min, rangeMeta.employees.max, state.employees);
    };

    positionsInput.addEventListener("input", (event) => {
      state.positions = clampInput(Number((event.target as HTMLInputElement).value), rangeMeta.positions.min, rangeMeta.positions.max);
      render();
    });

    hourlyRateInput.addEventListener("input", (event) => {
      state.hourlyRate = clampInput(Number((event.target as HTMLInputElement).value), rangeMeta.hourlyRate.min, rangeMeta.hourlyRate.max);
      render();
    });

    employeesInput.addEventListener("input", (event) => {
      state.employees = clampInput(Number((event.target as HTMLInputElement).value), rangeMeta.employees.min, rangeMeta.employees.max);
      render();
    });

    render();
  </script>

  <style>
    .calculator-range {
      appearance: none;
      -webkit-appearance: none;
      height: 12px;
      border-radius: 999px;
      outline: none;
      background: linear-gradient(90deg, rgba(226, 231, 237, 1) 0%, rgba(226, 231, 237, 1) 100%);
    }

    .calculator-range::-webkit-slider-runnable-track {
      height: 12px;
      border-radius: 999px;
      background: transparent;
    }

    .calculator-range::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 26px;
      height: 26px;
      border-radius: 999px;
      border: 3px solid #fff;
      background: #9aa3b0;
      box-shadow: 0 10px 24px rgba(92, 104, 120, 0.2);
      margin-top: -7px;
    }

    .calculator-range::-webkit-slider-thumb:hover {
      filter: brightness(0.92);
    }

    .calculator-range::-moz-range-track {
      height: 12px;
      border-radius: 999px;
      background: transparent;
    }

    .calculator-range::-moz-range-thumb {
      width: 26px;
      height: 26px;
      border-radius: 999px;
      border: 3px solid #fff;
      background: #9aa3b0;
      box-shadow: 0 10px 24px rgba(92, 104, 120, 0.2);
    }

    .calculator-range::-moz-range-thumb:hover {
      filter: brightness(0.92);
    }
  </style>
</section>
