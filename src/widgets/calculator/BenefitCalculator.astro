---
/*
File purpose: render the landing page calculator as a compact, centered pricing block.
Why this exists: the page needs a clean comparison widget without the extra explanatory panels from the previous version.
What it does: accepts three inputs, recalculates the self-run and turnkey estimates live, and presents the result in a minimal card layout.
Connected to: `src/shared/lib/benefit-calculator.ts`, `src/shared/ui/card/Card.astro`, and the CTA section below the calculator.
*/

import Card from "@/shared/ui/card/Card.astro";
import Icon from "@/shared/ui/icon/Icon.astro";
---

<section id="calculator" class="scroll-mt-32 px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
  <div class="mx-auto max-w-4xl">
    <div class="mx-auto max-w-2xl text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-[color:var(--border)] bg-white px-3 py-1.5 text-[color:var(--brand)]">
        <Icon name="trending-down" size={14} />
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--text-soft)]">Калькулятор</span>
      </div>
      <h2 class="mt-4 text-3xl leading-[0.96] sm:text-4xl lg:text-5xl">Калькулятор выгоды</h2>
    </div>

    <Card class="mt-10 overflow-hidden p-6 sm:p-8 lg:p-10">
      <div class="grid gap-4 md:grid-cols-3">
        <label class="block">
          <span class="mb-3 block text-sm font-semibold text-[color:var(--text-muted)]">Количество позиций</span>
          <input
            data-field="positions"
            type="number"
            min="1"
            max="24"
            step="1"
            value="4"
            class="w-full rounded-2xl border border-[color:var(--border)] bg-white px-4 py-3 text-lg font-semibold text-[color:var(--text)] outline-none transition focus:border-[color:var(--brand)] focus:ring-2 focus:ring-[color:var(--brand-soft)]"
          />
        </label>

        <label class="block">
          <span class="mb-3 block text-sm font-semibold text-[color:var(--text-muted)]">Час сотрудника</span>
          <input
            data-field="hourlyRate"
            type="number"
            min="800"
            max="20000"
            step="100"
            value="2500"
            class="w-full rounded-2xl border border-[color:var(--border)] bg-white px-4 py-3 text-lg font-semibold text-[color:var(--text)] outline-none transition focus:border-[color:var(--brand)] focus:ring-2 focus:ring-[color:var(--brand-soft)]"
          />
        </label>

        <label class="block">
          <span class="mb-3 block text-sm font-semibold text-[color:var(--text-muted)]">Количество сотрудников</span>
          <input
            data-field="employees"
            type="number"
            min="1"
            max="50"
            step="1"
            value="3"
            class="w-full rounded-2xl border border-[color:var(--border)] bg-white px-4 py-3 text-lg font-semibold text-[color:var(--text)] outline-none transition focus:border-[color:var(--brand)] focus:ring-2 focus:ring-[color:var(--brand-soft)]"
          />
        </label>
      </div>

      <div class="mt-8 grid gap-3 sm:grid-cols-3">
        <div class="rounded-[24px] bg-[#f4f7fb] p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--text-soft)]">Если сами</p>
          <p data-field="selfCost" class="mt-3 text-3xl font-semibold text-[color:var(--text)]">0 ₽</p>
        </div>

        <div class="rounded-[24px] bg-[linear-gradient(135deg,rgba(28,79,215,0.12),rgba(255,255,255,0.9))] p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--brand)]">Под ключ</p>
          <p data-field="agencyCost" class="mt-3 text-3xl font-semibold text-[color:var(--text)]">0 ₽</p>
        </div>

        <div class="rounded-[24px] border border-[color:var(--border)] p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--text-soft)]">Экономия</p>
          <p data-field="savings" class="mt-3 text-3xl font-semibold text-[color:var(--success)]">0 ₽</p>
        </div>
      </div>
    </Card>
  </div>

  <script>
    /*
     * Bind the three number fields to the shared pricing model.
     * This keeps the calculator lean, avoids framework overhead, and makes the live estimate easy to maintain with the rest of the landing page.
     */
    import {
      calculateBenefitComparison,
      clampInput,
      formatRubles,
    } from "@/shared/lib/benefit-calculator";

    const root = document.querySelector<HTMLElement>("#calculator");

    if (!root) {
      throw new Error("Calculator root was not found.");
    }

    const positionsInput = root.querySelector<HTMLInputElement>('[data-field="positions"]');
    const hourlyRateInput = root.querySelector<HTMLInputElement>('[data-field="hourlyRate"]');
    const employeesInput = root.querySelector<HTMLInputElement>('[data-field="employees"]');

    const selfCost = root.querySelector<HTMLElement>('[data-field="selfCost"]');
    const agencyCost = root.querySelector<HTMLElement>('[data-field="agencyCost"]');
    const savings = root.querySelector<HTMLElement>('[data-field="savings"]');

    if (!positionsInput || !hourlyRateInput || !employeesInput || !selfCost || !agencyCost || !savings) {
      throw new Error("Calculator outputs were not found.");
    }

    const state = {
      positions: 4,
      hourlyRate: 2500,
      employees: 3,
    };

    /*
     * Push the current state into the result cards on every input change.
     * The section is intentionally compact, so the render step only updates the values the visitor actually cares about.
     */
    const render = () => {
      const result = calculateBenefitComparison(state);

      positionsInput.value = String(state.positions);
      hourlyRateInput.value = String(state.hourlyRate);
      employeesInput.value = String(state.employees);
      selfCost.textContent = formatRubles(result.selfCost);
      agencyCost.textContent = formatRubles(result.agencyCost);
      savings.textContent = formatRubles(result.savings);
    };

    positionsInput.addEventListener("input", (event) => {
      state.positions = clampInput(Number((event.target as HTMLInputElement).value), 1, 24);
      render();
    });

    hourlyRateInput.addEventListener("input", (event) => {
      state.hourlyRate = clampInput(Number((event.target as HTMLInputElement).value), 800, 20000);
      render();
    });

    employeesInput.addEventListener("input", (event) => {
      state.employees = clampInput(Number((event.target as HTMLInputElement).value), 1, 50);
      render();
    });

    render();
  </script>
</section>
