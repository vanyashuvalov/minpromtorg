---
/*
File purpose: present the key reasons to choose the service.
Why this exists: the landing page needs a trust layer that addresses decision-making beyond the pure process description.
What it does: highlights the operational and communication advantages that reduce uncertainty for the client.
Connected to: the calculator, process, and testimonial sections, because this is the proof bridge between promise and validation.
*/

import { site } from "@/shared/config/site";
import Card from "@/shared/ui/card/Card.astro";
import type { CoolIconName } from "@/shared/lib/coolicons";
import Icon from "@/shared/ui/icon/Icon.astro";
import Section from "@/shared/ui/section/Section.astro";

const reasonIcons: CoolIconName[] = ["chat-conversation", "list-check", "clock", "user-check"];
---

<Section id="reasons" title={site.reasons.title}>
  <div class="grid gap-4 lg:grid-cols-2">
    {site.reasons.items.map((item, index) => (
      <Card class="h-full p-6">
        <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-[color:var(--brand-soft)] text-[color:var(--brand)]">
          <Icon name={reasonIcons[index]} size={20} />
        </div>
        <h3 class="mt-4 text-2xl leading-tight">{item.title}</h3>
        <p class="mt-4 text-sm leading-7 text-[color:var(--text-muted)]">{item.text}</p>
      </Card>
    ))}
  </div>
</Section>
