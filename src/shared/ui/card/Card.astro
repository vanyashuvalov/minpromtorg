---
/*
File purpose: standardize card surfaces across the landing page.
Why this exists: the page uses several boxed content patterns, and keeping them consistent makes the UI feel intentional instead of assembled from random fragments.
What it does: wraps slotted content in a reusable rounded shell with optional tone and padding variants.
Connected to: all widgets that need a shared surface treatment, especially hero, calculator, testimonials, and CTA blocks.
*/

import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"div"> {
  tone?: "light" | "dark" | "accent";
  class?: string;
  padding?: "sm" | "md" | "lg";
}

const { tone = "light", padding = "md", class: className, ...rest } = Astro.props as Props;

const toneClasses = {
  light: "glass-panel text-[color:var(--text)]",
  dark: "glass-panel-dark text-white",
  accent:
    "bg-[linear-gradient(135deg,rgba(28,79,215,0.12),rgba(233,184,115,0.18))] text-[color:var(--text)] border border-white/60 shadow-[0_24px_70px_rgba(28,79,215,0.12)]",
} as const;

const paddingClasses = {
  sm: "p-4",
  md: "p-6",
  lg: "p-8",
} as const;
---

<div
  class:list={[
    "card-shell rounded-[var(--radius-xl)]",
    toneClasses[tone],
    paddingClasses[padding],
    className,
  ]}
  {...rest}
>
  <slot />
</div>

<style>
  .card-shell {
    transform: translateZ(0);
    will-change: transform, box-shadow, border-color;
    transition-property: transform, box-shadow, border-color;
    transition-duration: 200ms;
    transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  }

  .card-shell:hover {
    transform: translate3d(0, -5px, 0);
    box-shadow: 0 36px 110px rgba(15, 23, 42, 0.18);
  }

  @media (prefers-reduced-motion: reduce) {
    .card-shell {
      transition: none;
    }

    .card-shell:hover {
      transform: none;
    }
  }
</style>
